

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  engineType = "client"
  // "nodejs" so the generated client runs on Vercel's Node serverless runtime.
  // (Still runs fine under Bun locally — Bun is Node-compatible.)
  runtime = "nodejs"
  // Emit ".js" import extensions in the generated client (default is ".ts"). On Vercel the
  // .ts files compile to .js and run under Node's strict ESM resolver, which needs the real
  // runtime extension — ".ts" specifiers would 404 at boot. Bun still resolves ".js"→".ts" locally.
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
  // NOTE: pgvector is enabled directly in Supabase (Dashboard → Database → Extensions,
  // or `CREATE EXTENSION vector`). We deliberately do NOT let Prisma manage extensions
  // (`extensions = [...]`) — on Supabase that makes `prisma migrate dev` flag Supabase's
  // own pre-installed extensions as "drift" and threaten a destructive reset.
}


//definig schema

model User {
  id         String        @id          @default(uuid())
  email      String        @unique
  name       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt  
  provider    AuthProvider
  supabaseId  String
  conversations Conversation[]
  gmailConnection GmailConnection?

}

model Conversation {
  id              String          @id  @default(uuid())
  title           String?
  slug            String
  userId          String
  createdAt       DateTime        @default(now())   // sidebar can now sort newest-first
  messages        Message[]
  user            User           @relation(fields: [userId], references: [id])


}

// Semantic cache for /perplexity_ask. One row per answered query, keyed by the
// query's embedding. A new query is embedded and compared (cosine distance via
// pgvector's <=>) against these rows; a close-enough, non-stale row is replayed
// instead of paying for a fresh Tavily search + LLM generation.
// Accessed ONLY via $queryRaw/$executeRaw (the `embedding` vector type isn't part
// of Prisma's typed client), so this model exists mainly to drive the migration.
model CachedQuery {
  id        String                      @id @default(uuid())
  queryText String                      @map("query_text")
  model     String                                            // cache is keyed on (embedding, model)
  embedding Unsupported("vector(1536)")                       // 1536 = text-embedding-3-small
  answer    String
  sources   Json
  images    Json
  createdAt DateTime                    @default(now())       @map("created_at")

  @@map("cached_query")
}

model Message {
  id             Int          @id        @default(autoincrement())
  content        String
  role           MessageRole
  conversation   Conversation         @relation(fields: [conversationId], references: [id])
  conversationId String
  createdId      DateTime           @default(now())
  
}

// Per-user Gmail connection (the "Connectors" feature). One OAuth grant per user.
// The refresh token is stored ENCRYPTED (AES-256-GCM): `refreshTokenEnc` is the ciphertext,
// with its own unique `iv` (12-byte GCM nonce) and `authTag`. The AES key lives in env
// (GMAIL_TOKEN_ENC_KEY), NEVER in the DB — so a database leak alone can't read the tokens.
// Short-lived access tokens (~1h) are NOT stored; we mint them on demand from the refresh token.
model GmailConnection {
  id              String   @id @default(uuid())
  userId          String   @unique                       // Supabase user id — one connection per user
  googleEmail     String   @map("google_email")          // the connected Gmail address (display + sanity check)
  refreshTokenEnc String   @map("refresh_token_enc")      // AES-256-GCM ciphertext (base64)
  iv              String                                  // GCM nonce (base64), unique per encryption
  authTag         String   @map("auth_tag")               // GCM auth tag (base64)
  scopes          String                                  // space-delimited granted scopes
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_connection")
}

enum MessageRole {
  user
  Assistant
}

enum AuthProvider {
  Github
  Google
}

